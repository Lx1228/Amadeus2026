# 依赖（npm install 可重装）
node_modules/
amadeus/node_modules/

# Next.js 构建产物（next build 可重建）
.next/
out/
amadeus/.next/
amadeus/out/

# Tauri / Rust 编译产物（可重建）
amadeus/src-tauri/target/
amadeus/src-tauri/gen/

# 环境变量 / 密钥（不传 GitHub）
.env
.env.local
.env.*.local
amadeus/.env
amadeus/.env.local
amadeus/.env.*.local

# 允许 .env.example（模板文件，需要提交到 Git）
!.env.example
!amadeus/.env.example

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# 日志
*.log
npm-debug.log*

